# Copy this file to secrets.properties (gitignored) in this same directory
# and fill in real values. Never commit secrets.properties.
#
# See prompt-android-app.md's "Build-time configuration & the secrets"
# section for what each of these is and why they're hardcoded at build time
# rather than entered at runtime.

# themoviedb.org → Settings → API. Same key convention as the web app's
# TMDB_API_KEY (movie-data-manager/.env) — required for TMDB search/details.
TMDB_API_KEY=

# Google AI Studio → API keys. Powers the memo-add LLM pipeline (Call A/Call B).
GEMINI_API_KEY=

# GitHub → Settings → Developer settings → Fine-grained personal access
# tokens. Scope to the nambin/nambin.github.io repository ONLY, with
# "Contents: Read and write" permission and nothing else. Used to commit
# data/movies.yml directly via the Contents API.
GITHUB_TOKEN=
