{
  "name": "movie-data-manager-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static web editor for the movie collection YAML.",
  "scripts": {
    "test": "node --test \"tests/**/*.test.js\"",
    "build": "esbuild lib/app.js --bundle --format=esm --minify --define:__GEMINI_KEY__=\"\\\"\\\"\" --outfile=assets/movies_editor.js",
    "build:dev": "node scripts/build-dev.mjs",
    "watch": "esbuild lib/app.js --bundle --format=esm --define:__GEMINI_KEY__=\"\\\"\\\"\" --outfile=assets/movies_editor.js --watch",
    "capture:fixtures": "node scripts/capture-fixtures.mjs"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
