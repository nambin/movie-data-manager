# Copy this file to `.env` and fill in your own values. `.env` is gitignored.
# The binary auto-loads `.env` from the working directory on startup. Lines
# starting with `#` and blank lines are ignored. Values already set in the
# environment take precedence over this file (so a one-off `$env:VAR =` wins).

# Gemini API key for LLM.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# TMDB API key for movie data fetching.
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=